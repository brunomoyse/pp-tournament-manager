{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off"
  },
  "rules": {
    "typescript/no-explicit-any": "warn",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-debugger": "error"
  },
  "ignorePatterns": [
    ".nuxt/",
    ".output/",
    "dist/",
    "node_modules/",
    "ios/",
    "android/",
    "playwright-report/",
    "test-results/"
  ]
}
